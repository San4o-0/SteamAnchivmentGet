# --- Steam Web API ---
# Отримати ключ: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_web_api_key_here

# --- Auth ---
# Секрет для підпису JWT (згенеруй: python -c "import secrets;print(secrets.token_hex(32))")
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE_MINUTES=10080

# Куди Steam OpenID поверне користувача (публічний URL самого API у проді).
# Прод-приклад (Render): BASE_URL=https://achivo-api.onrender.com
BASE_URL=http://localhost:8000
# Куди врешті відправити користувача з токеном (фронтенд). {token} підставляється.
# Прод: FRONTEND_RETURN_URL=https://achivo.pages.dev/auth/callback#token={token}
FRONTEND_RETURN_URL=http://localhost:5173/auth/callback#token={token}

# --- Database ---
# Прод: postgresql+asyncpg://user:pass@host:5432/db
# Локально без Postgres можна лишити sqlite (кеш у файлі)
DATABASE_URL=postgresql+asyncpg://sam:sam@localhost:5432/sam

# --- Локальний агент розблокування (Потік 2) ---
AGENT_URL=http://127.0.0.1:57343

# --- CORS ---
# Прод: додай origin фронтенду, напр.
# CORS_ORIGINS=https://achivo.pages.dev
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://achivo.pages.dev

# --- Кеш ---
# Скільки секунд дані Steam вважаються свіжими
CACHE_TTL_SECONDS=1800
