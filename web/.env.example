# Base URL of the REST backend (Потік 1). Empty = same origin (works with MSW mocks).
VITE_API_BASE_URL=

# Set to "false" to talk to the real backend instead of the MSW mock layer.
VITE_ENABLE_MOCKS=true

# URL to download the local unlock agent (SAM.Agent). Shown as a button in the
# banner when the agent is offline. Leave empty to hide the download button.
VITE_AGENT_DOWNLOAD_URL=
