# Base URL of the REST backend (Потік 1) — READ path only: profile, library,
# achievements, stats. Empty = same origin (works with MSW mocks).
# NB: health/unlock do NOT go here — the browser calls the local agent DIRECTLY
# at http://127.0.0.1:57343 (see src/api/agent.ts), so a hosted backend never
# needs to reach the user's loopback.
VITE_API_BASE_URL=

# Set to "false" to talk to the real backend instead of the MSW mock layer.
VITE_ENABLE_MOCKS=true

# URL to download the local unlock agent bundle (AchivoAgent.zip, produced by
# SAM.Agent/build-dist.ps1). Shown as the "Download agent" button in the banner
# when the agent is offline. Leave empty to hide the button.
VITE_AGENT_DOWNLOAD_URL=
